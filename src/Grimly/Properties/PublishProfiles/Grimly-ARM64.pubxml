<?xml version="1.0" encoding="utf-8"?>
<!--
    Publish Grimly for Windows on ARM64 (Snapdragon NPU target).
    Output lands in <repo>/publish-arm64/ as GrimlyARM64.exe + dependencies.

    CLI:  dotnet publish src/Grimly/Grimly.csproj \
              -p:PublishProfile=Grimly-ARM64

    The PublishDir name was chosen to match its sibling publish-x64/.
    NOTE: the existing publish/ folder still holds the previous ARM64 build —
    renaming it to publish-arm64/ is blocked by OneDrive Files-On-Demand.
    Until that's resolved manually, this profile will create publish-arm64/
    alongside the stale publish/.
-->
<Project>
  <PropertyGroup>
    <Configuration>Release</Configuration>
    <Platform>Any CPU</Platform>
    <PublishDir>..\..\publish-arm64\</PublishDir>
    <PublishProtocol>FileSystem</PublishProtocol>
    <TargetFramework>net9.0-windows</TargetFramework>
    <RuntimeIdentifier>win-arm64</RuntimeIdentifier>
    <SelfContained>true</SelfContained>
    <PublishSingleFile>true</PublishSingleFile>
    <!-- WPF has native DLLs (wpfgfx_cor3, PresentationNative_cor3, etc.) that
         must be bundled inside the single exe and extracted on first run. -->
    <IncludeNativeLibrariesForSelfExtract>true</IncludeNativeLibrariesForSelfExtract>
    <EnableCompressionInSingleFile>true</EnableCompressionInSingleFile>
    <PublishReadyToRun>true</PublishReadyToRun>
    <AssemblyName>GrimlyARM64</AssemblyName>
  </PropertyGroup>
</Project>
