<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!--
        Grimly (dark) theme. Defines every brush key the Core views reference via
        DynamicResource. Theme is referenced via DynamicResource throughout the UI.
        Apps pick one by merging it into Application.Resources.
    -->

    <!-- ===== Surfaces ===== -->
    <SolidColorBrush x:Key="PopupBackgroundBrush" Color="#F0202020"/>
    <SolidColorBrush x:Key="PopupBorderBrush" Color="#44FFFFFF"/>
    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#1E1E1E"/>
    <SolidColorBrush x:Key="FloatingIconBackgroundBrush" Color="#DD222222"/>
    <SolidColorBrush x:Key="FloatingIconBorderBrush" Color="#44FFFFFF"/>

    <!-- ===== Text foregrounds ===== -->
    <SolidColorBrush x:Key="PrimaryForegroundBrush" Color="White"/>
    <SolidColorBrush x:Key="BodyForegroundBrush" Color="#CCCCCC"/>
    <SolidColorBrush x:Key="TitleForegroundBrush" Color="#CCCCCC"/>
    <SolidColorBrush x:Key="SubtleForegroundBrush" Color="#888888"/>
    <SolidColorBrush x:Key="MutedForegroundBrush" Color="#777777"/>
    <SolidColorBrush x:Key="DimForegroundBrush" Color="#666666"/>
    <SolidColorBrush x:Key="ListItemForegroundBrush" Color="#AAAAAA"/>
    <SolidColorBrush x:Key="LogForegroundBrush" Color="#AAAAAA"/>
    <SolidColorBrush x:Key="ReadOnlyForegroundBrush" Color="#999999"/>
    <SolidColorBrush x:Key="SelectionLabelForegroundBrush" Color="#AAAAAA"/>

    <!-- ===== Inputs (opaque, used in Settings/Install) ===== -->
    <SolidColorBrush x:Key="InputBackgroundBrush" Color="#2D2D2D"/>
    <SolidColorBrush x:Key="InputForegroundBrush" Color="White"/>
    <SolidColorBrush x:Key="InputBorderBrush" Color="#444444"/>
    <SolidColorBrush x:Key="InputReadOnlyBackgroundBrush" Color="#222222"/>

    <!-- ===== Inputs (translucent, used in popup over transparent window) ===== -->
    <SolidColorBrush x:Key="TranslucentInputBackgroundBrush" Color="#33FFFFFF"/>
    <SolidColorBrush x:Key="TranslucentInputBorderBrush" Color="#44FFFFFF"/>
    <SolidColorBrush x:Key="WorkingTextBackgroundBrush" Color="#18FFFFFF"/>
    <SolidColorBrush x:Key="WorkingTextForegroundBrush" Color="#EEEEEE"/>
    <SolidColorBrush x:Key="WorkingTextBorderBrush" Color="#33FFFFFF"/>
    <SolidColorBrush x:Key="ReviewBackgroundBrush" Color="#18FFFFFF"/>
    <SolidColorBrush x:Key="ReviewForegroundBrush" Color="#CCCCCC"/>

    <!-- ===== ListBox ===== -->
    <SolidColorBrush x:Key="ListBoxBackgroundBrush" Color="#252525"/>
    <SolidColorBrush x:Key="ListBoxBorderBrush" Color="#444444"/>
    <SolidColorBrush x:Key="ListItemHoverBackgroundBrush" Color="#3A3A3A"/>
    <SolidColorBrush x:Key="ListItemHoverForegroundBrush" Color="White"/>
    <SolidColorBrush x:Key="ListItemSelectedBackgroundBrush" Color="#2A4A2A"/>
    <SolidColorBrush x:Key="ListItemSelectedForegroundBrush" Color="#A0D8A0"/>

    <!-- ===== Pill buttons (mode selector) ===== -->
    <SolidColorBrush x:Key="PillBackgroundBrush" Color="#33FFFFFF"/>
    <SolidColorBrush x:Key="PillForegroundBrush" Color="White"/>
    <SolidColorBrush x:Key="PillHoverBackgroundBrush" Color="#4488AAFF"/>
    <SolidColorBrush x:Key="PillPressedBackgroundBrush" Color="#6688AAFF"/>
    <SolidColorBrush x:Key="PillAppliedBackgroundBrush" Color="#2A4A2A"/>
    <SolidColorBrush x:Key="PillAppliedBorderBrush" Color="#4A8A4A"/>
    <SolidColorBrush x:Key="PillAppliedForegroundBrush" Color="#A0D8A0"/>
    <SolidColorBrush x:Key="PillAppliedCheckBrush" Color="#80C080"/>
    <SolidColorBrush x:Key="PillAppliedHoverBackgroundBrush" Color="#3A5A3A"/>
    <SolidColorBrush x:Key="PillAppliedPressedBackgroundBrush" Color="#4A6A4A"/>

    <!-- ===== Action buttons ===== -->
    <!-- Primary affirmative (Paste, Save, Close-on-success) -->
    <SolidColorBrush x:Key="AcceptButtonBackgroundBrush" Color="#2D7D2D"/>
    <SolidColorBrush x:Key="AcceptButtonForegroundBrush" Color="White"/>
    <!-- Smaller affirmative (Accept All, Accept Selected) -->
    <SolidColorBrush x:Key="AcceptSmallBackgroundBrush" Color="#2D6B2D"/>
    <SolidColorBrush x:Key="AcceptSmallForegroundBrush" Color="#DDDDDD"/>
    <!-- Negative (Undo, Reject All, Reject Selected) -->
    <SolidColorBrush x:Key="RejectButtonBackgroundBrush" Color="#6B3030"/>
    <SolidColorBrush x:Key="RejectButtonForegroundBrush" Color="#DDDDDD"/>
    <!-- Neutral (Retry, Copy) -->
    <SolidColorBrush x:Key="NeutralButtonBackgroundBrush" Color="#555555"/>
    <SolidColorBrush x:Key="NeutralButtonForegroundBrush" Color="White"/>
    <!-- Dismiss/Cancel -->
    <SolidColorBrush x:Key="DismissButtonBackgroundBrush" Color="#444444"/>
    <SolidColorBrush x:Key="DismissButtonForegroundBrush" Color="#CCCCCC"/>
    <!-- Warning (Reconnect) -->
    <SolidColorBrush x:Key="WarningButtonBackgroundBrush" Color="#4A3A20"/>
    <SolidColorBrush x:Key="WarningButtonForegroundBrush" Color="#DDB866"/>
    <!-- Title-bar close (X) -->
    <SolidColorBrush x:Key="TitleBarCloseForegroundBrush" Color="#888888"/>

    <!-- ===== Banners / status ===== -->
    <SolidColorBrush x:Key="ErrorForegroundBrush" Color="#FF6666"/>
    <SolidColorBrush x:Key="SuccessBannerBackgroundBrush" Color="#2A4A2A"/>
    <SolidColorBrush x:Key="SuccessBannerForegroundBrush" Color="#A0D8A0"/>
    <SolidColorBrush x:Key="FailureBannerBackgroundBrush" Color="#4A2A2A"/>
    <SolidColorBrush x:Key="FailureBannerForegroundBrush" Color="#D88080"/>

    <!-- ===== Install log ===== -->
    <SolidColorBrush x:Key="LogBackgroundBrush" Color="#0E0E0E"/>
    <SolidColorBrush x:Key="LogBorderBrush" Color="#333333"/>

    <!-- ===== Slider ===== -->
    <SolidColorBrush x:Key="SliderForegroundBrush" Color="White"/>

    <!-- ===== Typography ===== -->
    <!-- Base font size for the editable working text and the review diff area. -->
    <sys:Double x:Key="WorkingFontSize">13</sys:Double>

    <!-- ===== Diff colors (review area) =====
         Foreground for each change state + translucent background tints that
         overlay the review textbox. Consumed by EditorPopupWindow.xaml.cs. -->
    <SolidColorBrush x:Key="DiffUnchangedForeground"      Color="#B4B4B4"/>
    <SolidColorBrush x:Key="DiffPendingRemovedForeground" Color="#DC6464"/>
    <SolidColorBrush x:Key="DiffPendingAddedForeground"   Color="#50DC50"/>
    <SolidColorBrush x:Key="DiffPendingAddedBackground"   Color="#2800B400"/>
    <SolidColorBrush x:Key="DiffAcceptedForeground"       Color="#78C878"/>
    <SolidColorBrush x:Key="DiffAcceptedBackground"       Color="#1E00A000"/>
    <SolidColorBrush x:Key="DiffRejectedForeground"       Color="#787878"/>
    <SolidColorBrush x:Key="DiffRejectedBackground"       Color="#14FF0000"/>
    <SolidColorBrush x:Key="DiffHoverBackground"          Color="#286496FF"/>

</ResourceDictionary>
