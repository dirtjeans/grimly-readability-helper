<Window x:Class="Grimly.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:Grimly.Models"
        Title="Grimly Settings"
        Width="460" SizeToContent="Height"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="{DynamicResource WindowBackgroundBrush}">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource BodyForegroundBrush}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,8,0,4"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{DynamicResource InputBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource InputForegroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource InputBorderBrush}"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="{DynamicResource InputBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource InputForegroundBrush}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="4,4"/>
        </Style>
    </Window.Resources>

    <StackPanel Margin="20">

        <!-- Foundry Status -->
        <DockPanel Margin="0,0,0,8">
            <TextBlock Text="Foundry Local:" FontWeight="SemiBold" Margin="0"
                       VerticalAlignment="Center"/>
            <TextBlock x:Name="StatusIndicator" Margin="8,0,0,0"
                       VerticalAlignment="Center" FontSize="13">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Foreground" Value="{DynamicResource SubtleForegroundBrush}"/>
                        <Setter Property="Text" Value="{Binding FoundryStatus}"/>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
        </DockPanel>

        <!-- Foundry Endpoint (read-only, auto-detected) -->
        <TextBlock Text="Endpoint (auto-detected)" FontWeight="SemiBold"/>
        <TextBox Text="{Binding FoundryEndpoint}" IsReadOnly="True"
                 Background="{DynamicResource InputReadOnlyBackgroundBrush}" Foreground="{DynamicResource ReadOnlyForegroundBrush}"/>

        <!-- Model selector -->
        <DockPanel Margin="0,8,0,4">
            <TextBlock Text="Model" FontWeight="SemiBold" Margin="0"
                       VerticalAlignment="Center"/>
            <Button DockPanel.Dock="Right" Content="Refresh"
                    Padding="8,2" FontSize="11" Margin="8,0,0,0"
                    HorizontalAlignment="Right"
                    Command="{Binding RefreshModelsCommand}"/>
        </DockPanel>
        <TextBox x:Name="ModelTextBox"
                 Text="{Binding ModelName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                 Background="{DynamicResource InputBackgroundBrush}" Foreground="{DynamicResource InputForegroundBrush}"
                 BorderBrush="{DynamicResource InputBorderBrush}" Padding="6,4" FontSize="13"/>
        <ListBox x:Name="ModelListBox"
                 ItemsSource="{Binding AvailableModels}"
                 Background="{DynamicResource ListBoxBackgroundBrush}" Foreground="{DynamicResource ListItemForegroundBrush}"
                 BorderBrush="{DynamicResource ListBoxBorderBrush}" BorderThickness="1"
                 MaxHeight="100" Margin="0,2,0,0"
                 FontSize="12"
                 SelectionChanged="ModelListBox_SelectionChanged">
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="Padding" Value="6,3"/>
                    <Setter Property="Cursor" Value="Hand"/>
                    <Setter Property="Foreground" Value="{DynamicResource ListItemForegroundBrush}"/>
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="{DynamicResource ListItemHoverBackgroundBrush}"/>
                            <Setter Property="Foreground" Value="{DynamicResource ListItemHoverForegroundBrush}"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="{DynamicResource ListItemSelectedBackgroundBrush}"/>
                            <Setter Property="Foreground" Value="{DynamicResource ListItemSelectedForegroundBrush}"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </ListBox.ItemContainerStyle>
        </ListBox>
        <ProgressBar IsIndeterminate="True" Height="3" Margin="0,2,0,0"
                     Visibility="{Binding IsLoadingModels, Converter={StaticResource BoolToVis}}"/>

        <!-- Hotkey -->
        <TextBlock Text="Hotkey" FontWeight="SemiBold"/>
        <StackPanel Orientation="Horizontal">
            <TextBox Text="{Binding HotkeyModifiers}" Width="120" Margin="0,0,8,0"/>
            <TextBlock Text="+" VerticalAlignment="Center" Margin="0,0,8,0"/>
            <TextBox Text="{Binding HotkeyKey}" Width="60"/>
        </StackPanel>

        <TextBlock FontWeight="SemiBold">
            <Run Text="Creativity: "/>
            <Run Text="{Binding Creativity, StringFormat='{}{0:F1}', Mode=OneWay}"/>
            <Run Text=" " Foreground="{DynamicResource SubtleForegroundBrush}" FontSize="11"/>
            <Run Foreground="{DynamicResource SubtleForegroundBrush}" FontSize="11">
                <Run.Text>
                    <Binding Path="Creativity" StringFormat="{}">
                        <Binding.Converter>
                            <local:CreativityLabelConverter xmlns:local="clr-namespace:Grimly.Converters"/>
                        </Binding.Converter>
                    </Binding>
                </Run.Text>
            </Run>
        </TextBlock>
        <Slider Minimum="0" Maximum="1" Value="{Binding Creativity}"
                TickFrequency="0.1" IsSnapToTickEnabled="True"
                Foreground="{DynamicResource SliderForegroundBrush}"/>

        <DockPanel Margin="0,8,0,4">
            <TextBlock Text="Max Tokens" FontWeight="SemiBold" Margin="0"
                       VerticalAlignment="Center"/>
            <TextBlock Text="{Binding MaxTokensInfo}" Foreground="{DynamicResource SubtleForegroundBrush}"
                       FontSize="11" Margin="8,0,0,0" VerticalAlignment="Center"/>
        </DockPanel>
        <TextBox Text="{Binding MaxTokens}"/>

        <TextBlock Text="{Binding PopupOpacity, StringFormat='Popup Opacity: {0:P0}'}" FontWeight="SemiBold"/>
        <Slider Minimum="0.5" Maximum="1" Value="{Binding PopupOpacity}"
                TickFrequency="0.05" IsSnapToTickEnabled="True"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Reset Defaults" Padding="12,6" Margin="0,0,8,0"
                    Command="{Binding ResetDefaultsCommand}"/>
            <Button Content="Save" Padding="16,6" Margin="0,0,8,0"
                    Command="{Binding SaveCommand}"
                    Background="{DynamicResource AcceptButtonBackgroundBrush}" Foreground="{DynamicResource AcceptButtonForegroundBrush}"/>
            <Button Content="Cancel" Padding="12,6"
                    Command="{Binding CancelCommand}"/>
        </StackPanel>
    </StackPanel>
</Window>
