<Window x:Class="Grimly.Views.ToastWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="480" SizeToContent="Height"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ShowActivated="False"
        Focusable="False"
        ResizeMode="NoResize"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <!-- ScaleTransform lives on the Border, not the Window, because WPF
         Window-level RenderTransforms are flaky with AllowsTransparency. -->
    <Border x:Name="RootBorder"
            CornerRadius="10"
            Padding="0"
            Background="{DynamicResource PopupBackgroundBrush}"
            BorderBrush="{DynamicResource PopupBorderBrush}"
            BorderThickness="1"
            Cursor="Hand"
            RenderTransformOrigin="0.5,0.5">
        <Border.RenderTransform>
            <ScaleTransform x:Name="RootScale" ScaleX="0.92" ScaleY="0.92"/>
        </Border.RenderTransform>
        <Border.Effect>
            <DropShadowEffect BlurRadius="32" Opacity="0.45" ShadowDepth="6"/>
        </Border.Effect>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Width="5"
                    CornerRadius="10,0,0,10"
                    Background="{DynamicResource AcceptButtonBackgroundBrush}"/>

            <StackPanel Grid.Column="1" Margin="20,16,20,16">
                <TextBlock x:Name="TitleText"
                           Foreground="{DynamicResource TitleForegroundBrush}"
                           FontSize="16" FontWeight="SemiBold"
                           Margin="0,0,0,6"/>
                <TextBlock x:Name="MessageText"
                           Foreground="{DynamicResource BodyForegroundBrush}"
                           FontSize="13"
                           LineHeight="18"
                           TextWrapping="Wrap"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
