<Window x:Class="Grimly.Views.EditorPopupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:Grimly.ViewModels"
        xmlns:models="clr-namespace:Grimly.Models"
        xmlns:converters="clr-namespace:Grimly.Converters"
        Title="Grimly"
        Width="620" SizeToContent="Height"
        MaxHeight="750"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ShowActivated="True"
        ResizeMode="NoResize"
        Loaded="Window_Loaded"
        KeyDown="Window_KeyDown">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <converters:ConnectionStatusToBrushConverter x:Key="StatusBrush"/>
        <converters:ReadabilityScoreToBrushConverter x:Key="ReadabilityBrush"/>

        <!-- Mode pill button style -->
        <Style x:Key="PillButton" TargetType="Button">
            <Setter Property="Foreground" Value="{DynamicResource PillForegroundBrush}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{DynamicResource PillBackgroundBrush}"
                                CornerRadius="12"
                                Padding="12,6"
                                Cursor="Hand">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource PillHoverBackgroundBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource PillPressedBackgroundBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Applied mode pill button style (checkmark + green tint) -->
        <Style x:Key="PillButtonApplied" TargetType="Button">
            <Setter Property="Foreground" Value="{DynamicResource PillAppliedForegroundBrush}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{DynamicResource PillAppliedBackgroundBrush}"
                                CornerRadius="12"
                                Padding="12,6"
                                BorderBrush="{DynamicResource PillAppliedBorderBrush}"
                                BorderThickness="1"
                                Cursor="Hand">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <TextBlock Text="&#x2713; " FontSize="10" VerticalAlignment="Center"
                                           Foreground="{DynamicResource PillAppliedCheckBrush}"/>
                                <ContentPresenter VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource PillAppliedHoverBackgroundBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource PillAppliedPressedBackgroundBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Outline button style — transparent fill, colored border + text.
             Subtle background tint on hover. -->
        <Style x:Key="OutlineButton" TargetType="Button">
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="Transparent"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource PillHoverBackgroundBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource PillPressedBackgroundBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Action button style -->
        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.85"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="{DynamicResource PopupBackgroundBrush}"
            CornerRadius="12"
            Padding="16"
            BorderBrush="{DynamicResource PopupBorderBrush}"
            BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" Opacity="0.6" ShadowDepth="4"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>  <!-- 0  Title bar -->
                <RowDefinition Height="Auto"/>  <!-- 1  Hint text -->
                <RowDefinition Height="Auto"/>  <!-- 2  Mode selector -->
                <RowDefinition Height="Auto"/>  <!-- 3  (reserved) -->
                <RowDefinition Height="Auto"/>  <!-- 4  Custom prompt -->
                <RowDefinition Height="Auto"/>  <!-- 5  Text label + Undo -->
                <RowDefinition Height="Auto"/>  <!-- 6  Working text -->
                <RowDefinition Height="Auto"/>  <!-- 7  Status indicators -->
                <RowDefinition Height="Auto"/>  <!-- 8  Loading indicator -->
                <RowDefinition Height="Auto"/>  <!-- 9  Review header -->
                <RowDefinition Height="Auto"/>  <!-- 10 Selection toolbar -->
                <RowDefinition Height="*"/>     <!-- 11 Review area -->
                <RowDefinition Height="Auto"/>  <!-- 12 Violations panel (Style Helper only) -->
                <RowDefinition Height="Auto"/>  <!-- 13 Error -->
                <RowDefinition Height="Auto"/>  <!-- 14 Buttons -->
            </Grid.RowDefinitions>

            <!-- Title bar. Holds the app name on the left, the connection
                 indicator on the right (before the close button), and the
                 close button on the far right. Connection indicator lives
                 here so the readability row has its full width for the
                 Match Word button, and because connection is app-level
                 status — naturally at home in the title bar. -->
            <DockPanel Grid.Row="0" Margin="0,-4,0,8" Background="Transparent"
                       MinHeight="28" Cursor="SizeAll"
                       MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Button DockPanel.Dock="Right" Content="X"
                        Background="Transparent" Foreground="{DynamicResource TitleBarCloseForegroundBrush}"
                        FontSize="14" Padding="8,2"
                        HorizontalAlignment="Right"
                        Style="{StaticResource ActionButton}"
                        Command="{Binding DismissCommand}"/>
                <!-- Connection indicator: dot + full status text (includes
                     the active model name when connected). Click to re-check.
                     MaxWidth + TextTrimming guard against unusually long
                     model strings; the tooltip shows the full text either way. -->
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                            VerticalAlignment="Center" Margin="0,0,10,0"
                            Cursor="Hand" Background="Transparent"
                            MouseLeftButtonDown="StatusLed_Click"
                            ToolTip="{Binding ConnectionStatusText}">
                    <Ellipse Width="9" Height="9" Margin="0,0,6,0"
                             VerticalAlignment="Center"
                             Fill="{Binding ConnectionStatus, Converter={StaticResource StatusBrush}}"/>
                    <TextBlock Text="{Binding ConnectionStatusText}"
                               Foreground="{DynamicResource MutedForegroundBrush}" FontSize="11"
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis"
                               MaxWidth="360"/>
                </StackPanel>
                <TextBlock Text="{DynamicResource AppDisplayName}"
                           Foreground="{DynamicResource TitleForegroundBrush}" FontSize="14" FontWeight="SemiBold"
                           VerticalAlignment="Center"/>
            </DockPanel>

            <!-- Hint text. Only visible when the host couldn't read the
                 selection from the source app (IsManualPasteMode). In the
                 normal success path (text was captured cleanly) this row
                 stays collapsed — the captured text is already visible in
                 the working-text box and the hint would be redundant.
                 A second, more specific hint shown inside the working-text
                 area explains *why* capture failed; this one tells the user
                 what to do. -->
            <TextBlock Grid.Row="1"
                       Text="Select text in another app, or paste here (Ctrl+V), then pick a revision below."
                       Foreground="{DynamicResource DimForegroundBrush}" FontSize="12" FontStyle="Italic"
                       TextWrapping="Wrap" Margin="0,0,0,8">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding IsManualPasteMode}" Value="True"/>
                                    <Condition Binding="{Binding HasResult}" Value="False"/>
                                    <Condition Binding="{Binding IsLoading}" Value="False"/>
                                </MultiDataTrigger.Conditions>
                                <Setter Property="Visibility" Value="Visible"/>
                            </MultiDataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>

            <!-- Mode selector -->
            <WrapPanel Grid.Row="2" x:Name="ModePanel" Margin="0,0,0,8"/>

            <!-- (Row 3 reserved — Style Helper used to put a dedicated style-pipeline
                 button here; Grimly leaves it empty so subsequent rows keep their indices.) -->

            <!-- Custom prompt input -->
            <TextBox Grid.Row="4"
                     x:Name="CustomPromptTextBox"
                     Text="{Binding CustomPrompt, UpdateSourceTrigger=PropertyChanged}"
                     Visibility="{Binding IsCustomMode, Converter={StaticResource BoolToVis}}"
                     Background="{DynamicResource TranslucentInputBackgroundBrush}" Foreground="{DynamicResource PrimaryForegroundBrush}"
                     BorderBrush="{DynamicResource TranslucentInputBorderBrush}" BorderThickness="1"
                     Padding="8,6" Margin="0,0,0,8"
                     FontSize="12"
                     AcceptsReturn="False"
                     KeyDown="CustomPromptTextBox_KeyDown"
                     ToolTip="Type your instruction and press Enter"/>

            <!-- Text label + Undo -->
            <DockPanel Grid.Row="5" Margin="0,0,0,4">
                <TextBlock Text="Text:" Foreground="{DynamicResource SubtleForegroundBrush}" FontSize="11"
                           VerticalAlignment="Center"/>
                <Button DockPanel.Dock="Right" Content="Undo"
                        Background="{DynamicResource RejectButtonBackgroundBrush}" Foreground="{DynamicResource RejectButtonForegroundBrush}"
                        Style="{StaticResource ActionButton}"
                        Padding="10,3" FontSize="11"
                        HorizontalAlignment="Right"
                        Command="{Binding UndoCommand}"
                        Visibility="{Binding CanUndo, Converter={StaticResource BoolToVis}}"/>
            </DockPanel>

            <!-- Working text (editable, hidden during review). Wrapped in a
                 Grid so we can overlay a placeholder TextBlock when the popup
                 opened as a manual-paste fallback — the "can't read selection"
                 message sits where the user expects their selected text to
                 appear. As soon as they paste anything, the TextBox.Text
                 becomes non-empty, the placeholder's WorkingText="" condition
                 fails, and the overlay hides — their pasted text naturally
                 takes its place. IsHitTestVisible=False ensures clicks go
                 through to the underlying TextBox. -->
            <Grid Grid.Row="6" Margin="0,0,0,8">
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Setter Property="Visibility" Value="Visible"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsReviewing}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>

                <TextBox x:Name="WorkingTextInput"
                         Text="{Binding WorkingText, UpdateSourceTrigger=PropertyChanged}"
                         Background="{DynamicResource WorkingTextBackgroundBrush}" Foreground="{DynamicResource WorkingTextForegroundBrush}"
                         BorderBrush="{DynamicResource WorkingTextBorderBrush}" BorderThickness="1"
                         Padding="8"
                         MinHeight="60" MaxHeight="180"
                         TextWrapping="Wrap"
                         AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"
                         FontSize="{DynamicResource WorkingFontSize}"/>

                <!-- Placeholder overlay for the manual-paste fallback. Shown
                     only when the popup opened without a UIA selection AND
                     the TextBox is still empty. Disappears the instant the
                     user pastes anything. -->
                <TextBlock Text="Can't read selected text in that app. Copy the text (Ctrl+C), then paste here (Ctrl+V)."
                           Foreground="{DynamicResource SubtleForegroundBrush}"
                           FontSize="{DynamicResource WorkingFontSize}"
                           FontStyle="Italic"
                           TextWrapping="Wrap"
                           Margin="10,10,10,10"
                           IsHitTestVisible="False">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding IsManualPasteMode}" Value="True"/>
                                        <Condition Binding="{Binding WorkingText}" Value=""/>
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="Visibility" Value="Visible"/>
                                </MultiDataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Grid>

            <!-- Readability / Match Word row. Connection LED moved to the
                 bottom (next to Paste/Copy/Dismiss) to give this row the full
                 width — "Match Word" was getting truncated when both the long
                 model-name string and the readability label had to share one
                 line. -->
            <DockPanel Grid.Row="7" Margin="0,2,0,6" LastChildFill="False">
                <!-- Readability score (right) -->
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ReadabilityLabel}" Value="">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <Ellipse Width="10" Height="10" Margin="0,0,6,0"
                             VerticalAlignment="Center"
                             Fill="{Binding ReadabilityScore, Converter={StaticResource ReadabilityBrush}}"/>
                    <TextBlock Text="{Binding ReadabilityLabel}"
                               Foreground="{DynamicResource MutedForegroundBrush}" FontSize="12"
                               VerticalAlignment="Center"/>
                    <!-- Match Word: compute the precise Flesch via Word COM.
                         Visible only when Word is installed; disabled while a
                         query is in flight or after the current text was just
                         matched (to avoid redundant calls).
                         Foreground uses NeutralButtonForegroundBrush (white-ish
                         in both themes) for readable contrast against the
                         grey/dark button background; MutedForegroundBrush was
                         too close to the background. -->
                    <Button Margin="10,0,0,0" Padding="8,2" FontSize="11"
                            VerticalAlignment="Center" Cursor="Hand"
                            Background="{DynamicResource NeutralButtonBackgroundBrush}"
                            Foreground="{DynamicResource NeutralButtonForegroundBrush}"
                            Command="{Binding MatchWordCommand}"
                            Visibility="{Binding IsWordMatchAvailable, Converter={StaticResource BoolToVis}}"
                            ToolTip="Compute the exact Flesch score using Microsoft Word">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource ActionButton}">
                                <Setter Property="Content" Value="Match Word"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsMatchingWord}" Value="True">
                                        <Setter Property="Content" Value="Matching..."/>
                                        <Setter Property="IsEnabled" Value="False"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsWordMatched}" Value="True">
                                        <Setter Property="Content" Value="✓ Matched"/>
                                        <Setter Property="IsEnabled" Value="False"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </DockPanel>

            <!-- Loading indicator -->
            <StackPanel Grid.Row="8" Orientation="Horizontal" Margin="0,0,0,8"
                        Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}">
                <ProgressBar IsIndeterminate="True" Width="120" Height="4" Margin="0,0,8,0"/>
                <TextBlock Text="Revising..." Foreground="{DynamicResource SubtleForegroundBrush}" FontSize="11"
                           VerticalAlignment="Center"/>
            </StackPanel>

            <!-- Review header with Accept All / Reject All -->
            <DockPanel Grid.Row="9" Margin="0,0,0,4"
                       Visibility="{Binding IsReviewing, Converter={StaticResource BoolToVis}}">
                <TextBlock Text="Review changes (click to toggle):" Foreground="{DynamicResource SubtleForegroundBrush}"
                           FontSize="11" VerticalAlignment="Center"/>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                            HorizontalAlignment="Right">
                    <Button Content="Accept All" Background="{DynamicResource AcceptSmallBackgroundBrush}" Foreground="{DynamicResource AcceptSmallForegroundBrush}"
                            Style="{StaticResource ActionButton}"
                            Padding="8,3" FontSize="10" Margin="0,0,4,0"
                            Command="{Binding AcceptAllChangesCommand}"/>
                    <Button Content="Reject All" Background="{DynamicResource RejectButtonBackgroundBrush}" Foreground="{DynamicResource RejectButtonForegroundBrush}"
                            Style="{StaticResource ActionButton}"
                            Padding="8,3" FontSize="10"
                            Command="{Binding RejectAllChangesCommand}"/>
                </StackPanel>
            </DockPanel>

            <!-- Selection toolbar (appears when text is selected in review area) -->
            <StackPanel Grid.Row="10" x:Name="SelectionToolbar"
                        Orientation="Horizontal" Margin="0,0,0,4"
                        Visibility="Collapsed">
                <TextBlock x:Name="SelectionLabel" Text="" Foreground="{DynamicResource SelectionLabelForegroundBrush}"
                           FontSize="10" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <Button Content="Accept Selected" Background="{DynamicResource AcceptSmallBackgroundBrush}" Foreground="{DynamicResource AcceptSmallForegroundBrush}"
                        Style="{StaticResource ActionButton}"
                        Padding="8,3" FontSize="10" Margin="0,0,4,0"
                        Click="AcceptSelected_Click"/>
                <Button Content="Reject Selected" Background="{DynamicResource RejectButtonBackgroundBrush}" Foreground="{DynamicResource RejectButtonForegroundBrush}"
                        Style="{StaticResource ActionButton}"
                        Padding="8,3" FontSize="10"
                        Click="RejectSelected_Click"/>
            </StackPanel>

            <!-- Review area (interactive diff with clickable changes) -->
            <RichTextBox Grid.Row="11"
                         x:Name="ReviewDisplay"
                         IsReadOnly="True"
                         Background="{DynamicResource ReviewBackgroundBrush}"
                         Foreground="{DynamicResource ReviewForegroundBrush}"
                         BorderThickness="0"
                         Padding="8" Margin="0,0,0,8"
                         MinHeight="80" MaxHeight="250"
                         VerticalScrollBarVisibility="Auto"
                         FontSize="{DynamicResource WorkingFontSize}"
                         Cursor="Arrow"
                         SelectionChanged="ReviewDisplay_SelectionChanged"
                         Visibility="{Binding IsReviewing, Converter={StaticResource BoolToVis}}">
                <FlowDocument>
                    <Paragraph x:Name="ReviewParagraph"/>
                </FlowDocument>
            </RichTextBox>

            <!-- Violations panel (Style Helper Pass C). Visible when checking or when
                 violations exist; hidden otherwise. ItemsControl scrolls if the list
                 exceeds MaxHeight so the action buttons stay reachable. -->
            <Border Grid.Row="12"
                    Background="{DynamicResource WorkingTextBackgroundBrush}"
                    BorderBrush="{DynamicResource WorkingTextBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="4"
                    Padding="8" Margin="0,0,0,8">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding HasViolations}" Value="True">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <StackPanel>
                    <!-- Header / Quick Fix / spinner row -->
                    <DockPanel Margin="0,0,0,4">
                        <TextBlock Text="Style check"
                                   Foreground="{DynamicResource SubtleForegroundBrush}"
                                   FontSize="11" FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                        <!-- Quick Fix turns the auto-fixable items into a
                             reviewable diff (same accept/reject UX as Fix
                             Grammar). Hidden when nothing is auto-fixable. -->
                        <Button DockPanel.Dock="Right"
                                Content="Quick Fix"
                                Style="{StaticResource ActionButton}"
                                Background="{DynamicResource NeutralButtonBackgroundBrush}"
                                Foreground="{DynamicResource NeutralButtonForegroundBrush}"
                                Padding="10,2" FontSize="11" Margin="8,0,0,0"
                                Command="{Binding ApplyQuickFixesCommand}"
                                Visibility="{Binding HasAutoFixableViolations, Converter={StaticResource BoolToVis}}"
                                ToolTip="Apply all mechanical fixes — review with accept/reject"/>
                    </DockPanel>

                    <!-- Hint: tells the user where to go next. Always visible
                         when the panel is open since both Quick Fix and the
                         AI buttons are relevant in nearly every scenario. -->
                    <TextBlock Margin="0,0,0,6"
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource SubtleForegroundBrush}"
                               FontSize="10"
                               FontStyle="Italic"
                               Text="{Binding QuickFixHint}"/>

                    <!-- Violation list -->
                    <ItemsControl ItemsSource="{Binding Violations}">
                        <ItemsControl.Template>
                            <ControlTemplate TargetType="ItemsControl">
                                <ScrollViewer MaxHeight="160" VerticalScrollBarVisibility="Auto">
                                    <ItemsPresenter/>
                                </ScrollViewer>
                            </ControlTemplate>
                        </ItemsControl.Template>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <DockPanel Margin="0,2,0,2">
                                    <Border DockPanel.Dock="Left"
                                            Background="{DynamicResource PillAppliedBackgroundBrush}"
                                            CornerRadius="3" Padding="6,1" Margin="0,1,6,0"
                                            VerticalAlignment="Top">
                                        <TextBlock Text="{Binding Category}"
                                                   Foreground="{DynamicResource PillAppliedForegroundBrush}"
                                                   FontSize="10" FontWeight="SemiBold"/>
                                    </Border>
                                    <TextBlock TextWrapping="Wrap"
                                               Foreground="{DynamicResource BodyForegroundBrush}"
                                               FontSize="11">
                                        <Run Text="“" Foreground="{DynamicResource SubtleForegroundBrush}"/><Run Text="{Binding Quote, Mode=OneWay}" FontStyle="Italic"/><Run Text="”" Foreground="{DynamicResource SubtleForegroundBrush}"/><Run Text="  —  " Foreground="{DynamicResource SubtleForegroundBrush}"/><Run Text="{Binding Explanation, Mode=OneWay}"/>
                                    </TextBlock>
                                </DockPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- Error message + retry/reconnect -->
            <StackPanel Grid.Row="13" Margin="0,0,0,8">
                <StackPanel.Style>
                    <Style TargetType="StackPanel">
                        <Setter Property="Visibility" Value="Visible"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ErrorMessage}" Value="{x:Null}">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </StackPanel.Style>
                <TextBlock Text="{Binding ErrorMessage}"
                           Foreground="{DynamicResource ErrorForegroundBrush}" FontSize="12"
                           TextWrapping="Wrap" Margin="0,0,0,6"/>
                <StackPanel Orientation="Horizontal"
                            Visibility="{Binding ShowRetry, Converter={StaticResource BoolToVis}}">
                    <Button Content="Retry" Background="{DynamicResource NeutralButtonBackgroundBrush}" Foreground="{DynamicResource NeutralButtonForegroundBrush}"
                            Style="{StaticResource ActionButton}"
                            Padding="10,4" FontSize="11" Margin="0,0,6,0"
                            Command="{Binding RetryCommand}"/>
                    <Button Content="Reconnect" Background="{DynamicResource WarningButtonBackgroundBrush}" Foreground="{DynamicResource WarningButtonForegroundBrush}"
                            Style="{StaticResource ActionButton}"
                            Padding="10,4" FontSize="11"
                            Command="{Binding ReconnectCommand}"
                            ToolTip="Restart Foundry Local service and reload the model"/>
                </StackPanel>
            </StackPanel>

            <!-- Action buttons. Connection indicator now lives in the title
                 bar so this row belongs entirely to Paste/Copy/Dismiss. -->
            <DockPanel Grid.Row="14" Margin="0,4,0,0" LastChildFill="False">
                <!-- Action buttons (right-aligned) -->
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                            HorizontalAlignment="Right">
                    <Button Content="Paste"
                            Background="{DynamicResource AcceptButtonBackgroundBrush}" Foreground="{DynamicResource AcceptButtonForegroundBrush}"
                            Style="{StaticResource ActionButton}"
                            Command="{Binding AcceptCommand}"
                            Margin="0,0,8,0"/>
                    <Button Content="Copy"
                            Background="{DynamicResource NeutralButtonBackgroundBrush}" Foreground="{DynamicResource NeutralButtonForegroundBrush}"
                            Style="{StaticResource ActionButton}"
                            Command="{Binding CopyResultCommand}"
                            Margin="0,0,8,0"/>
                    <Button Content="Dismiss"
                            Background="{DynamicResource DismissButtonBackgroundBrush}" Foreground="{DynamicResource DismissButtonForegroundBrush}"
                            Style="{StaticResource ActionButton}"
                            Command="{Binding DismissCommand}"/>
                </StackPanel>
            </DockPanel>
        </Grid>
    </Border>
</Window>
