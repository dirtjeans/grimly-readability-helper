<Window x:Class="Grimly.Views.FloatingIconWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="28" Height="28"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ShowActivated="False"
        Focusable="False"
        ResizeMode="NoResize"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Border CornerRadius="14"
            Background="{DynamicResource FloatingIconBackgroundBrush}"
            BorderBrush="{DynamicResource FloatingIconBorderBrush}"
            BorderThickness="1"
            Cursor="Hand">
        <Border.Effect>
            <DropShadowEffect BlurRadius="8" Opacity="0.5" ShadowDepth="2"/>
        </Border.Effect>

        <Image Source="pack://application:,,,/Resources/FloatingIcon.png"
               Stretch="UniformToFill"
               RenderOptions.BitmapScalingMode="HighQuality"
               HorizontalAlignment="Center"
               VerticalAlignment="Center"/>
    </Border>
</Window>
